FROM oven/bun:1 AS deps
WORKDIR /app
COPY package.json bun.lock bunfig.toml turbo.json tsconfig.base.json ./
COPY packages/contracts/package.json packages/contracts/package.json
COPY clients/web/package.json clients/web/package.json
RUN bun install --frozen-lockfile

FROM oven/bun:1 AS build
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
ARG API_ORIGIN=http://localhost:3001
ENV API_ORIGIN=$API_ORIGIN
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN bun run --filter @repo/contracts build \
 && bun run --filter @repo/web build

FROM oven/bun:1 AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
COPY --from=build /app/clients/web/.next/standalone ./
COPY --from=build /app/clients/web/.next/static ./clients/web/.next/static
COPY --from=build /app/clients/web/public ./clients/web/public
EXPOSE 3000
CMD ["bun", "run", "clients/web/server.js"]
