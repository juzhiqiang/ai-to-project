{
  "compilerOptions": {
    // 编译目标：使用 ES2022 语法，比 ESNext 更具体，兼顾现代性和稳定性
    "target": "ES2022",
    // 模块系统：使用现代的 ES 模块
    "module": "ESNext",
    // 模块解析策略：设置为针对构建工具（如 Bun, Vite, Next.js）优化的模式
    "moduleResolution": "Bundler",
    // 启用所有严格的类型检查选项
    "strict": true,
    // 跳过对第三方库声明文件的检查，加快编译速度
    "skipLibCheck": true,
    // 基准路径，用于解析下面的 paths 别名
    "baseUrl": ".",
    // 路径映射：允许在编辑器中直接跳转到源码，而不需要等待项目构建完成
    "paths": {
      "@repo/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@repo/contracts/*": [
        "packages/contracts/src/*"
      ]
    }
  }
}