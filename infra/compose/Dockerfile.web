FROM oven/bun:1-alpine AS base

WORKDIR /app
COPY package.json bun.lock bunfig.toml turbo.json tsconfig.base.json ./
COPY packages/contracts/package.json packages/contracts/package.json
COPY clients/web/package.json clients/web/package.json
COPY services/api/package.json services/api/package.json
RUN bun install --frozen-lockfile

COPY . .
ARG API_ORIGIN=http://api:3001
ENV API_ORIGIN=$API_ORIGIN
RUN ./packages/contracts/node_modules/.bin/tsc -p packages/contracts/tsconfig.json \
 && cd clients/web \
 && ./node_modules/.bin/next build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=base /app/clients/web/.next/standalone ./
COPY --from=base /app/clients/web/.next/static ./clients/web/.next/static
COPY --from=base /app/clients/web/public ./clients/web/public
WORKDIR /app/clients/web
EXPOSE 3000
CMD ["node", "server.js"]
